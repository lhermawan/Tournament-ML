generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model match {
  id                        String      @id
  seasonId                  String
  week                      Int
  teamAId                   String
  teamBId                   String
  winnerId                  String?
  scoreA                    Int?
  scoreB                    Int?
  mvpId                     String?
  screenshotUrl             String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime
  player                    player?     @relation(fields: [mvpId], references: [id], map: "Match_mvpId_fkey")
  season                    season      @relation(fields: [seasonId], references: [id], onDelete: Cascade, map: "Match_seasonId_fkey")
  team_match_teamAIdToteam  team        @relation("match_teamAIdToteam", fields: [teamAId], references: [id], map: "Match_teamAId_fkey")
  team_match_teamBIdToteam  team        @relation("match_teamBIdToteam", fields: [teamBId], references: [id], map: "Match_teamBId_fkey")
  team_match_winnerIdToteam team?       @relation("match_winnerIdToteam", fields: [winnerId], references: [id], map: "Match_winnerId_fkey")
  matchgame                 matchgame[]

  @@index([mvpId], map: "Match_mvpId_fkey")
  @@index([seasonId], map: "Match_seasonId_idx")
  @@index([teamAId], map: "Match_teamAId_fkey")
  @@index([teamBId], map: "Match_teamBId_fkey")
  @@index([winnerId], map: "Match_winnerId_fkey")
}

model matchgame {
  id            String   @id
  matchId       String
  gameNumber    Int
  winnerId      String?
  mvpId         String?
  mvpKills      Int      @default(0)
  mvpDeaths     Int      @default(0)
  mvpAssists    Int      @default(0)
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  match         match    @relation(fields: [matchId], references: [id], onDelete: Cascade, map: "MatchGame_matchId_fkey")
  player        player?  @relation(fields: [mvpId], references: [id], map: "MatchGame_mvpId_fkey")
  team          team?    @relation(fields: [winnerId], references: [id], map: "MatchGame_winnerId_fkey")

  @@unique([matchId, gameNumber], map: "MatchGame_matchId_gameNumber_key")
  @@index([mvpId], map: "MatchGame_mvpId_idx")
  @@index([winnerId], map: "MatchGame_winnerId_idx")
}

model player {
  id         String             @id
  userId     String             @unique(map: "Player_userId_key")
  nickname   String
  mlId       String
  phone      String
  unit       String
  rank       player_rank
  mainRole   player_mainRole
  secondRole player_secondRole?
  verified   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime
  match      match[]
  matchgame  matchgame[]
  user       user               @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Player_userId_fkey")
  teammember teammember[]
}

model season {
  id        String        @id
  name      String
  status    season_status @default(draft)
  createdAt DateTime      @default(now())
  updatedAt DateTime
  match     match[]
  team      team[]
}

model team {
  id                         String       @id
  seasonId                   String
  teamName                   String
  power                      Int          @default(0)
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime
  match_match_teamAIdToteam  match[]      @relation("match_teamAIdToteam")
  match_match_teamBIdToteam  match[]      @relation("match_teamBIdToteam")
  match_match_winnerIdToteam match[]      @relation("match_winnerIdToteam")
  matchgame                  matchgame[]
  season                     season       @relation(fields: [seasonId], references: [id], onDelete: Cascade, map: "Team_seasonId_fkey")
  teammember                 teammember[]

  @@index([seasonId], map: "Team_seasonId_idx")
}

model teammember {
  id       String              @id
  teamId   String
  playerId String
  laneRole teammember_laneRole
  player   player              @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "TeamMember_playerId_fkey")
  team     team                @relation(fields: [teamId], references: [id], onDelete: Cascade, map: "TeamMember_teamId_fkey")

  @@unique([teamId, laneRole], map: "TeamMember_teamId_laneRole_key")
  @@unique([teamId, playerId], map: "TeamMember_teamId_playerId_key")
  @@index([playerId], map: "TeamMember_playerId_fkey")
}

model user {
  id        String    @id
  name      String
  email     String    @unique(map: "User_email_key")
  password  String
  role      user_role @default(player)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  player    player?
}

enum season_status {
  draft
  registration
  locked
  league
  playoff
  completed
}

enum teammember_laneRole {
  Jungler
  Mid_Lane
  Gold_Lane
  EXP_Lane
  Roamer
}

enum user_role {
  admin
  player
}

enum player_rank {
  Master
  Grandmaster
  Epic
  Legend
  Mythic
}

enum player_mainRole {
  Jungler
  Mid_Lane
  Gold_Lane
  EXP_Lane
  Roamer
}

enum player_secondRole {
  Jungler
  Mid_Lane
  Gold_Lane
  EXP_Lane
  Roamer
}
